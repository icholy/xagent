shape: sequence_diagram

client: Client
c2: C2 Server
runner: Runner
agent: Agent\n(Container)
claude: Claude CLI
mcp: xagent MCP

client -> c2: CreateTask
c2 -> c2: Store task (pending)

runner -> c2: ListTasks (pending)
c2 -> runner: Task list

runner -> agent: Start container
runner -> c2: UpdateTask (running)

agent -> c2: GetTask
c2 -> agent: Task details

agent -> agent: Run setup commands

agent -> claude: claude --print "prompt"
claude -> claude: Run tools
claude -> mcp: create_link / report
mcp -> c2: CreateLink / UploadLogs
claude -> agent: Exit

agent -> c2: GetTask (poll for new prompts)
c2 -> agent: No new prompts

agent -> agent: Exit (code 0)

runner -> runner: Monitor detects container exit
runner -> c2: UpdateTask (completed)
