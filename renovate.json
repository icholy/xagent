{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits"],
  "minimumReleaseAge": "7 days",
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "groupName": "opentelemetry",
      "matchPackageNames": [
        "/^go.opentelemetry.io//",
        "/^@opentelemetry//"
      ]
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ]
}
