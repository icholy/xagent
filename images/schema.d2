direction: right

tasks: {
  shape: sql_table
  id: BIGSERIAL {constraint: primary_key}
  org_id: BIGINT {constraint: foreign_key}
  name: TEXT
  runner: TEXT
  workspace: TEXT
  status: INTEGER
  command: INTEGER
  version: BIGINT
  archived: BOOLEAN
  auto_archive: BIGINT
  created_at: TIMESTAMP
  updated_at: TIMESTAMP
}

task_links: {
  shape: sql_table
  id: BIGSERIAL {constraint: primary_key}
  task_id: BIGINT {constraint: foreign_key}
  relevance: TEXT
  url: TEXT
  title: TEXT
  subscribe: BOOLEAN
  routing_key: TEXT
  created_at: TIMESTAMP
}

events: {
  shape: sql_table
  id: BIGSERIAL {constraint: primary_key}
  org_id: BIGINT {constraint: foreign_key}
  task_id: BIGINT {constraint: foreign_key}
  type: TEXT
  wake: BOOLEAN
  payload: JSONB
  created_at: TIMESTAMP
}

workspaces: {
  shape: sql_table
  id: BIGSERIAL {constraint: primary_key}
  org_id: BIGINT {constraint: foreign_key}
  runner_id: TEXT
  name: TEXT
  description: TEXT
  updated_at: TIMESTAMP
}

keys: {
  shape: sql_table
  id: UUID {constraint: primary_key}
  org_id: BIGINT {constraint: foreign_key}
  name: TEXT
  token_hash: TEXT {constraint: unique}
  scopes: "TEXT[]"
  expires_at: TIMESTAMP
  created_at: TIMESTAMP
}

users: {
  shape: sql_table
  id: TEXT {constraint: primary_key}
  email: TEXT
  name: TEXT
  github_user_id: BIGINT
  github_username: TEXT
  atlassian_account_id: TEXT
  atlassian_username: TEXT
  created_at: TIMESTAMP
  updated_at: TIMESTAMP
  default_org_id: BIGINT {constraint: foreign_key}
}

orgs: {
  shape: sql_table
  id: BIGSERIAL {constraint: primary_key}
  name: TEXT {constraint: unique}
  owner: TEXT
  atlassian_webhook_secret: TEXT
  routing_rules: JSONB
  github_installation_id: BIGINT
  created_at: TIMESTAMP
  updated_at: TIMESTAMP
  archived: BOOLEAN
}

org_members: {
  shape: sql_table
  org_id: BIGINT {constraint: foreign_key}
  user_id: TEXT
  role: TEXT
  created_at: TIMESTAMP
}

pending_integrations: {
  shape: sql_table
  type: TEXT {constraint: primary_key}
  external_id: TEXT {constraint: primary_key}
  options: JSONB
  created_at: TIMESTAMP
}

# Relationships
org_members.org_id -> orgs.id
task_links.task_id -> tasks.id
tasks.org_id -> orgs.id
events.org_id -> orgs.id
events.task_id -> tasks.id
workspaces.org_id -> orgs.id
keys.org_id -> orgs.id
org_members.user_id -> users.id
orgs.owner -> users.id
users.default_org_id -> orgs.id
