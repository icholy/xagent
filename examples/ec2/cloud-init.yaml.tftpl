#cloud-config

package_update: true

apt:
  sources:
    docker:
      source: "deb [arch=$ARCH] https://download.docker.com/linux/ubuntu noble stable"
      keyid: 9DC858229FC7DD38854AE2D88D81803C0EBFCD88

packages:
  - docker-ce
  - docker-ce-cli
  - containerd.io
  - docker-compose-plugin
  - jq

write_files:
  - path: /opt/xagent/docker-compose.yml
    content: |
      ${indent(6, docker_compose)}

  - path: /opt/xagent/.env
    permissions: "0600"
    content: |
      ${indent(6, env_file_content)}

  - path: /opt/xagent/config/workspaces.yaml
    content: |
      ${indent(6, workspaces)}

runcmd:
  # Install sysbox
  - |
    ARCH=$(dpkg --print-architecture)
    SYSBOX_VERSION="0.7.0"
    wget -q "https://github.com/nestybox/sysbox/releases/download/v$${SYSBOX_VERSION}/sysbox-ce_$${SYSBOX_VERSION}-0.linux_$${ARCH}.deb" -O /tmp/sysbox.deb
    apt-get install -y /tmp/sysbox.deb
    rm /tmp/sysbox.deb
    systemctl enable sysbox
    systemctl start sysbox

  # Start docker compose
  - cd /opt/xagent && docker compose up -d
