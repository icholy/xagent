{
  "name": "xagent-icholy",
  "url": "https://xagent.choly.ca",
  "description": "Async agent orchestrator for Claude Code",
  "public": false,
  "request_oauth_on_install": false,
  "setup_on_update": false,
  "hook_attributes": {
    "url": "https://xagent.choly.ca/webhook/github",
    "active": true
  },
  "redirect_url": "https://xagent.choly.ca/github/callback",
  "setup_url": "https://xagent.choly.ca/ui/github/setup",
  "default_events": [
    "installation",
    "issue_comment",
    "pull_request_review",
    "pull_request_review_comment"
  ],
  "default_permissions": {
    "issues": "read",
    "metadata": "read",
    "pull_requests": "read"
  }
}
